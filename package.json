{
  "name": "@client-zone/npm",
  "author": "Lloyd Brookes <75pound@gmail.com>",
  "version": "0.4.1",
  "description": "An npm API client",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/client-zone/npm.git"
  },
  "type": "module",
  "exports": {
    "./downloads": "./lib/downloads.js",
    "./npms": "./lib/npms.js",
    "./registry": "./lib/registry.js",
    "./scrape": "./lib/scrape.js"
  },
  "keywords": [
    "npm",
    "api",
    "client"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "npm run dist && npm run test:ci",
    "test:ci": "75lb-nature test-runner test/*.js",
    "dist": "75lb-nature cjs-build index.js && 75lb-nature simple-rollup index.js",
    "dl": "node bin/downloads.js getUserDownloadHistory '\"75lb\"' > tmp/75lb-downloads.json"
  },
  "files": [
    "index.js",
    "dist",
    "lib"
  ],
  "dependencies": {
    "@client-zone/base": "^0.8.1",
    "array-back": "^6.2.2",
    "work": "file:../../75lb/work"
  },
  "standard": {
    "ignore": [
      "dist",
      "tmp"
    ],
    "envs": []
  }
}
