{
  "name": "@client-zone/npm",
  "author": "Lloyd Brookes <opensource@75lb.com> (http://75lb.com)",
  "version": "0.5.0",
  "description": "An API client to access npm download and registry data",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/client-zone/npm.git"
  },
  "type": "module",
  "exports": "./index.js",
  "keywords": [],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "npm run dist && npm run test:ci",
    "test:ci": "75lb-nature test-runner test/*.js",
