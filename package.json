{
  "name": "@client-zone/npm",
  "author": "Lloyd Brookes <75pound@gmail.com>",
  "version": "0.1.5",
  "description": "An npm API client",
  "repository": "https://github.com/client-zone/npm",
  "type": "module",
  "exports": {
    "./*": "./lib/*.js"
  },
  "keywords": ["npm", "api", "client"],
