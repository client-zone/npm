    "bin",
    "dist",
    "lib"
  ],
  "dependencies": {
    "api-client-base": "^0.1.2",
    "array-back": "^6.2.2",
    "work": "^0.10.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^21.0.1",
    "@rollup/plugin-node-resolve": "^13.1.3",
    "node-fetch": "^3.2.0",
    "rollup": "^2.66.1",
    "test-runner": "^0.10.1"
  }
}
